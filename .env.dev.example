NODE_ENV=development
PORT=3001
JWT_SECRET=dev_local_jwt_secret_change_in_production
ORIGIN_SECRET_KEY=

# App DB connection (must match MySQL container vars below)
DB_NAME=seekspotdb
DB_HOST=db
DB_USER=seekspot_user
DB_PASS=seekspot_pass

# MySQL container init vars — used by docker-compose.yml variable substitution
# Run with: docker compose --env-file .env.dev up
MYSQL_DATABASE=seekspotdb
MYSQL_ROOT_PASSWORD=root_dev_password
MYSQL_USER=seekspot_user
MYSQL_PASSWORD=seekspot_pass

# Not used in dev — email verification is skipped and code is logged to console
VERIFICATION_EMAIL_PASSWORD=
